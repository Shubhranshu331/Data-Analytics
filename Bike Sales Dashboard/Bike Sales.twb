      <column caption='Age Group' datatype='string' name='[Age_Group]' role='dimension' type='nominal' />
      <column caption='Year Filter' datatype='boolean' name='[Calculation_0901604226867202]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Date - Years] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='Chosen Year Profit' datatype='integer' name='[Calculation_0901604227125251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Date - Years]=[Parameters].[Parameter 1] THEN [Profit] END' />
      </column>
      <column caption='Last Year Profit' datatype='integer' name='[Calculation_0901604227530756]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Date - Years] = DATEADD(&apos;year&apos;,-1, [Parameters].[Parameter 1]) THEN [Profit] END' />
      </column>
      <column caption='YoY % Change' datatype='real' name='[Calculation_0901604228124677]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_0901604227125251]) - SUM([Calculation_0901604227530756]))/SUM([Calculation_0901604227530756])' />
      </column>
